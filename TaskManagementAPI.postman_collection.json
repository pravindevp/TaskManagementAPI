{
  "info": {
    "name": "Task Management API",
    "description": "Auth + CRUD endpoints for the Task Management API. Log in first; the token is saved automatically to the {{token}} variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://localhost:7080" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": [ "{{baseUrl}}" ], "path": [ "api", "auth", "register" ] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token saved.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": [ "{{baseUrl}}" ], "path": [ "api", "auth", "login" ] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"secret123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Get All Tasks",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": {
              "raw": "{{baseUrl}}/api/tasks?status=Pending",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "tasks" ],
              "query": [ { "key": "status", "value": "Pending", "description": "Optional: Pending | Completed | Expired" } ]
            }
          }
        },
        {
          "name": "Get Task By Id",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/tasks/1", "host": [ "{{baseUrl}}" ], "path": [ "api", "tasks", "1" ] }
          }
        },
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/tasks", "host": [ "{{baseUrl}}" ], "path": [ "api", "tasks" ] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Finish the assessment\",\n  \"description\": \"Submit before the deadline\",\n  \"dueDate\": \"2026-07-10T18:00:00Z\"\n}"
            }
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/tasks/1", "host": [ "{{baseUrl}}" ], "path": [ "api", "tasks", "1" ] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Finish the assessment\",\n  \"description\": \"Reviewed and completed\",\n  \"dueDate\": \"2026-07-10T18:00:00Z\",\n  \"status\": \"Completed\"\n}"
            }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/tasks/1", "host": [ "{{baseUrl}}" ], "path": [ "api", "tasks", "1" ] }
          }
        }
      ]
    }
  ]
}
